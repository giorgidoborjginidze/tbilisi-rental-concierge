// Prisma schema — STR / Aparthotel Operator Tool (Phase 1)
//
// Runs on SQLite locally. Kept Postgres-compatible for a later switch:
// no SQLite-only features; enum-like fields are Strings (documented below);
// money is Float for SQLite (switch to Decimal when moving to Postgres).

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// The account/customer: a professional STR/aparthotel operator.
model Operator {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String? // scrypt "salt:hash"; null only for legacy rows
  locale       String   @default("en") // "en" | "ka"
  createdAt    DateTime @default(now())

  units    Unit[]
  alerts   Alert[]
  assets   Asset[]
  incomes  IncomeRecord[]
  sessions Session[]
}

// A login session; id is the SHA-256 of the cookie token.
model Session {
  id         String   @id
  operatorId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
}

// A rentable unit (apartment, aparthotel room, studio...).
model Unit {
  id              String   @id @default(cuid())
  operatorId      String
  name            String
  nameKa          String? // Georgian display name
  city            String   @default("Tbilisi") // "Tbilisi" | "Batumi"
  district        String // e.g. "Vake", "Vera", "Saburtalo", "Old Town", "Mtatsminda", "Batumi Boulevard"
  address         String
  type            String // "apartment" | "aparthotel_room" | "studio" | "house"
  capacity        Int
  bedrooms        Int
  baseNightlyRate Float
  currency        String   @default("GEL")
  amenities       Json // string[] of amenity keys
  channelLinks    Json // { airbnbUrl?, bookingUrl?, icalUrls: string[] }
  createdAt       DateTime @default(now())

  operator           Operator            @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  leases             Lease[]
  pricingSuggestions PricingSuggestion[]
  alerts             Alert[]
  asset              Asset?

  @@index([operatorId])
  @@index([district])
}

// A short-term booking, imported from an iCal feed or entered manually.
// Guest PII kept minimal: guestName is optional (Georgian PDP law / GDPR).
model Booking {
  id         String   @id @default(cuid())
  unitId     String
  source     String // "airbnb" | "booking" | "direct" | "manual"
  guestName  String?
  checkIn    DateTime
  checkOut   DateTime
  nights     Int
  amount     Float?
  currency   String   @default("GEL")
  status     String   @default("confirmed") // "confirmed" | "cancelled" | "tentative"
  externalId String? // UID from the iCal event, used for dedupe
  importedAt DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, source, externalId])
  @@index([unitId, checkIn])
}

// A long-stay contract (aparthotel monthly stays / leases).
model Lease {
  id          String   @id @default(cuid())
  unitId      String
  tenantName  String?
  tenantPhone String? // for WhatsApp (door codes, notifications)
  startDate   DateTime
  endDate     DateTime
  monthlyRent Float
  currency    String   @default("GEL")
  status      String   @default("active") // "active" | "ended" | "upcoming"
  createdAt   DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, endDate])
}

// Output of the rule-based pricing engine, one row per unit per date.
model PricingSuggestion {
  id            String   @id @default(cuid())
  unitId        String
  date          DateTime
  suggestedRate Float
  currency      String   @default("GEL")
  reasons       Json // { factors: {...}, rationale: string }
  createdAt     DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, date])
}

// Neighborhood ADR / occupancy reference, per district per month.
// MVP rows are mock data behind the pluggable MarketDataSource interface.
model MarketBenchmark {
  id            String @id @default(cuid())
  district      String
  month         String // "YYYY-MM"
  adr           Float
  occupancyRate Float // 0..1
  sampleSize    Int
  source        String @default("mock")

  @@unique([district, month])
}

// A personal asset: real estate (apartment, house, commercial, land,
// garage) or movable property (vehicle, equipment). Tracks status,
// estimated value, and — via RentalContract — who rents it and until when.
model Asset {
  id             String   @id @default(cuid())
  operatorId     String
  name           String
  nameKa         String?
  category       String // "real_estate" | "vehicle" | "other"
  type           String // apartment | house | commercial | land | garage | car | equipment | other
  city           String?
  district       String?
  address        String?
  areaSqm        Float? // real estate only — drives market-rent estimate
  estimatedValue Float?
  currency       String   @default("GEL")
  status         String   @default("personal_use") // "rented" | "vacant" | "personal_use" | "listed"
  rentalMode     String   @default("long_term") // "long_term" | "daily"
  unitId         String?  @unique // optional link to an STR Unit (same property)
  // Per-platform listing URLs for this asset's own announcements.
  // Real estate: myhome/ss/airbnb/booking; vehicles: myauto.
  myhomeUrl      String?
  ssUrl          String?
  myautoUrl      String?
  airbnbUrl      String?
  bookingUrl     String?
  // Digital door key (daily rentals / handovers), sent via WhatsApp.
  doorCode            String?
  doorCodeGeneratedAt DateTime?
  notes          String?
  createdAt      DateTime @default(now())

  operator  Operator         @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  unit      Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  contracts RentalContract[]
  incomes   IncomeRecord[]

  @@index([operatorId])
}

// A long-term rental contract on an asset (apartment lease, car rental...).
model RentalContract {
  id          String   @id @default(cuid())
  assetId     String
  tenantName  String?
  tenantPhone String? // for WhatsApp (door codes, notifications)
  startDate   DateTime
  endDate     DateTime
  monthlyRent Float
  currency    String   @default("GEL")
  deposit     Float?
  status      String   @default("active") // "active" | "upcoming" | "ended"
  notes       String?
  createdAt   DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, endDate])
}

// A manual income entry (salary, dividend, one-off) — rent and STR income
// are derived from contracts and bookings; this covers everything else.
model IncomeRecord {
  id          String   @id @default(cuid())
  operatorId  String
  assetId     String?
  source      String // "rent" | "str" | "salary" | "business" | "dividend" | "other"
  description String?
  date        DateTime
  amount      Float
  currency    String   @default("GEL")
  createdAt   DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  asset    Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([operatorId, date])
}

// Long-term rent reference per district per month (GEL per m²). Mock for
// the MVP, same compliance stance as MarketBenchmark.
model RentBenchmark {
  id            String @id @default(cuid())
  district      String
  month         String // "YYYY-MM"
  avgRentPerSqm Float
  sampleSize    Int
  source        String @default("mock")

  @@unique([district, month])
}

// A proactive alert with a suggested action in its payload.
model Alert {
  id         String   @id @default(cuid())
  operatorId String
  unitId     String?
  type       String // "vacancy_gap" | "lease_expiry" | "underpriced"
  payload    Json // type-specific details + { suggestedAction: string }
  status     String   @default("open") // "open" | "dismissed" | "resolved"
  createdAt  DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([operatorId, status])
}
