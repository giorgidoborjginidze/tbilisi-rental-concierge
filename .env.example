# --- Database ---
# SQLite for local dev. Keep the schema Postgres-compatible so this can switch to
# postgresql://... later without code changes.
DATABASE_URL="file:./dev.db"

# --- Anthropic (Claude) ---
# Used for (a) extracting structured search criteria from free text and
# (b) generating one-line match explanations.
# If this is unset, the app falls back to a deterministic local stub so it still runs.
ANTHROPIC_API_KEY=""

# Optional model overrides (sensible defaults are used if unset).
# A smaller/cheaper model is fine for the extraction step.
ANTHROPIC_EXTRACTION_MODEL="claude-haiku-4-5"
ANTHROPIC_EXPLANATION_MODEL="claude-sonnet-5"

# --- Matching ---
# Listings not seen within this many days are treated as stale and excluded.
LISTING_STALE_AFTER_DAYS="21"
