# Copy to .env and fill in.

# Local SQLite database (path relative to the project root).
DATABASE_URL="file:./prisma/dev.db"

# Anthropic API key for pricing-suggestion rationales and the ops assistant.
# Optional: if missing, the app falls back to a deterministic local stub.
ANTHROPIC_API_KEY=""

# Finnhub API key for live stock prices (free tier at https://finnhub.io).
# Optional: if missing, stock prices fall back to Stooq (less reliable from
# cloud hosts). Crypto prices don't use this — they come from CoinGecko.
FINNHUB_API_KEY=""

# Flitt (payment gateway) merchant credentials. If unset, the app uses
# Flitt's public sandbox (merchant 1396424 / "test", currency USD) so the
# checkout flow is fully testable. For real payments, set your own:
#   FLITT_MERCHANT_ID  — your merchant id
#   FLITT_SECRET_KEY   — your merchant secret (keep private, never commit)
#   FLITT_CURRENCY     — "GEL" for a Georgian merchant
FLITT_MERCHANT_ID=""
FLITT_SECRET_KEY=""
FLITT_CURRENCY=""

# How often the local scheduler (npm run scheduler) runs the iCal sync.
SYNC_INTERVAL_MINUTES="60"

# Canonical public URL, used for SEO metadata, robots.txt and sitemap.xml.
# Set this in Vercel once a custom domain is connected, e.g.
#   NEXT_PUBLIC_SITE_URL="https://activo.world"
# If unset, it falls back to Vercel's production URL automatically (and to
# http://localhost:3000 in local development), so it's optional.
NEXT_PUBLIC_SITE_URL=""
